<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your public profile and social connections."
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_profile_card"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_avatar_green"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_user" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="18dp">

                    <TextView
                        android:id="@+id/txtName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Minh"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtBio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Music lover"
                        android:textColor="#AAAAAA"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/txtFollowInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 followers  •  0 following"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginTop="12dp" />

                    <Button
                        android:id="@+id/btnEditProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginTop="14dp"
                        android:text="Chỉnh sửa hồ sơ"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#2A2A2A" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/tabContainer"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="28dp">

                <View
                    android:id="@+id/tabIndicator"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_tab_selected" />

                <LinearLayout
                    android:id="@+id/tabButtonLayout"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnPublicPlaylists"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Public Playlists"
                        android:textColor="#000000"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnLiked"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Liked"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnPlayHistory"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Play History"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                </LinearLayout>

            </FrameLayout>

            <TextView
                android:id="@+id/txtSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Public Playlists"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="28dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProfileContent"
                android:layout_width="match_parent"
                android:layout_height="600dp"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="true" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="28dp"
                android:text="Đăng xuất"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#000000"
                android:backgroundTint="#1DB954" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#121212"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>